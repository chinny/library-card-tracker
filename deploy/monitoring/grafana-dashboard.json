{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 0,
  "schemaVersion": 39,
  "tags": ["library-card-tracker"],
  "templating": {
    "list": [
      {
        "name": "datasource",
        "type": "datasource",
        "query": "prometheus",
        "current": { "text": "Prometheus", "value": "${DS_PROMETHEUS}" },
        "hide": 0
      }
    ]
  },
  "time": { "from": "now-7d", "to": "now" },
  "title": "Library Card Tracker",
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Physical slots remaining",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "thresholds": { "mode": "absolute", "steps": [
            { "color": "red", "value": null },
            { "color": "yellow", "value": 3 },
            { "color": "green", "value": 6 }
          ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "library_remaining", "instant": true, "legendFormat": "{{member}} / {{system}}" }
      ]
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Scrape health",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "textMode": "value_and_name", "colorMode": "background" },
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "OK", "color": "green" } } }
          ],
          "thresholds": { "mode": "absolute", "steps": [ { "color": "red", "value": null }, { "color": "green", "value": 1 } ] }
        },
        "overrides": []
      },
      "targets": [
        { "refId": "A", "expr": "library_scrape_success", "instant": true, "legendFormat": "{{member}} / {{system}}" }
      ]
    },
    {
      "id": 3,
      "type": "timeseries",
      "title": "Physical checkouts over time",
      "datasource": { "type": "prometheus", "uid": "${datasource}" },
      "gridPos": { "h": 9, "w": 24, "x": 0, "y": 8 },
      "fieldConfig": { "defaults": { "custom": { "drawStyle": "line", "lineInterpolation": "stepAfter", "fillOpacity": 10 } }, "overrides": [] },
      "targets": [
        { "refId": "A", "expr": "library_checkouts_physical", "legendFormat": "{{member}} / {{system}}" },
        { "refId": "B", "expr": "library_checkout_limit", "legendFormat": "limit {{member}} / {{system}}" }
      ]
    }
  ]
}
