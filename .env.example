# Real values go in `.env` (gitignored) — never commit.

# Master key for at-rest PIN encryption (base64 of 32 bytes). Generate with:
#   npm run cli -- gen-key
# In production this is sourced from a k8s Secret, NOT a file.
LIBCARD_MASTER_KEY=

# Optional: path to the SQLite DB (default data/library.sqlite)
# LIBCARD_DB=data/library.sqlite

# ── Phase-1 harness only ────────────────────────────────────────────────────
# One pair per card id from config.json, upper-cased, non-alphanumerics -> "_":
#   id "card-1" -> LIBCARD_CARD_1_CARD / LIBCARD_CARD_1_PIN
# Used by `npm run dev` and `npm run cli -- import-config`. Once cards are in the
# encrypted DB, only LIBCARD_MASTER_KEY is needed at runtime.
LIBCARD_CARD_1_CARD=your-barcode-here
LIBCARD_CARD_1_PIN=your-pin-here

LIBCARD_CARD_2_CARD=your-barcode-here
LIBCARD_CARD_2_PIN=your-pin-here
